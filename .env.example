# ================================================================
#  루마네 AI 상담 서버 — 환경변수 예시
#  복사: cp .env.example .env  → 빈 값 채워서 사용
#  ⚠️ 실제 .env는 절대 커밋하지 말 것 (.gitignore에 등록되어 있음)
# ================================================================

# ── Anthropic (Claude API) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# (선택) dev/운영 분리 운용 시
# DEV_SUPABASE_URL=
# DEV_SUPABASE_SECRET_KEY=
# PROD_SUPABASE_URL=
# PROD_SUPABASE_SECRET_KEY=

# 운영(cloudtype)에서 스키마 분리 시 사용 (기본 public)
DB_SCHEMA=public

# ── 어드민 인증 ──────────────────────────────────────────────────
# 64자 이상 랜덤 hex 권장 (예: openssl rand -hex 32)
ADMIN_TOKEN=replace-with-random-64char-hex

# ── Notion (상담 기록 자동 저장) ─────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Make.com 웹훅 (선택 — Notion 저장 경유 시) ───────────────────
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/xxxxxxxxxxxxxx

# ── 서버 포트 ────────────────────────────────────────────────────
# 로컬: 3001 / Render·cloudtype은 자동 주입되므로 보통 비워둠
PORT=3001
